// Simplified pilot schema (2026-07): School → Class → Lesson.
// The previous multi-tenant/multi-subject design (Jamaat, SubAccount, Subject,
// teacher-authored CurriculumItem library) is archived, not deleted — see
// prisma/archive/schema.full-multitenant.prisma for the full-school/all-subject
// version to reintroduce later. Do not add SubAccount/Jamaat/Subject back into
// this file without a deliberate migration plan.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  city      String?
  joinCode  String   @unique
  tier      String   @default("pilot") // "demo" (test-run, 5-lesson set) | "pilot" (real school, full 20-lesson set)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  classes Class[]
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  role       String   @default("student") // "teacher" | "student" | "admin"
  isOrgAdmin Boolean  @default(false)
  orgId      String?
  avatar     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org Organization? @relation(fields: [orgId], references: [id])

  // Teacher relations
  taughtClasses      Class[]      @relation("TeacherClasses")
  createdAssignments Assignment[] @relation("AssignmentCreator")

  // Student relations
  enrollments Enrollment[]
  submissions Submission[]
  messages    AIMessage[]

  sessions Session[]
  accounts Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Class {
  id          String   @id @default(cuid())
  name        String
  description String?
  subject     String?
  gradeLevel  String
  teacherId   String
  orgId       String?
  code        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     User         @relation("TeacherClasses", fields: [teacherId], references: [id])
  org         Organization? @relation(fields: [orgId], references: [id])
  enrollments Enrollment[]
  assignments Assignment[]
}

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  classId    String
  enrollRole String   @default("student") // "student" | "ta" | "observer"
  joinedAt   DateTime @default(now())
  isActive   Boolean  @default(true)

  student User  @relation(fields: [studentId], references: [id])
  class   Class @relation(fields: [classId], references: [id])

  @@unique([studentId, classId])
}

model Assignment {
  id               String    @id @default(cuid())
  title            String
  description      String
  classId          String
  creatorId        String
  dueDate          DateTime?
  maxPoints        Int       @default(100)
  type             String    @default("written") // "written" | "code" | "quiz" | "ide"
  isPublished      Boolean   @default(false)
  allowedFileTypes String    @default("[]") // JSON array e.g. ["pdf","image","zip"]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  class       Class        @relation(fields: [classId], references: [id])
  creator     User         @relation("AssignmentCreator", fields: [creatorId], references: [id])
  submissions Submission[]
}

model Submission {
  id           String    @id @default(cuid())
  assignmentId String
  studentId    String
  content      String    @default("")
  fileUrl      String?
  grade        Float?
  feedback     String?
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?
  status       String    @default("submitted") // "submitted" | "graded" | "late"

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    User       @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
}

// The fixed Nuqta lesson catalog — seeded from content/pilot-curriculum/*.mdx,
// not authored by teachers. `tier` controls who can see it: "demo" lessons
// (the same 5 shown on learn.nuqta.dev) are visible to every org; "pilot"
// lessons (the other 15) are only visible to orgs with tier="pilot".
model CurriculumItem {
  id         String   @id @default(cuid())
  slug       String   @unique // matches the .mdx filename, e.g. "07-break-continue"
  title      String
  description String
  order      Int
  tier       String   @default("pilot") // "demo" | "pilot"
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AIMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" | "assistant"
  content   String
  sessionId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String
  event     String
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
}
